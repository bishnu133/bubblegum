{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Object Intelligence Seed Cases",
  "type": "object",
  "required": ["cases"],
  "additionalProperties": false,
  "properties": {
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "category",
          "channel",
          "platform_framework",
          "fixture_path",
          "instruction",
          "action_type",
          "target_text",
          "expected_target",
          "acceptable_refs",
          "expected_relation",
          "expected_graph_signals",
          "expected_confidence_range",
          "expected_failure_mode",
          "baseline_expectations",
          "tags"
        ],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "channel": { "type": "string", "enum": ["web", "mobile"] },
          "platform_framework": { "type": "string", "minLength": 1 },
          "fixture_path": { "type": "string", "minLength": 1 },
          "instruction": { "type": "string", "minLength": 1 },
          "action_type": { "type": "string", "minLength": 1 },
          "target_text": { "type": "string", "minLength": 1 },
          "expected_target": {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": true,
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          },
          "acceptable_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_relation": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "type": { "type": "string" },
                  "anchor_ref": { "type": "string" }
                }
              }
            ]
          },
          "expected_graph_signals": {
            "type": "object",
            "additionalProperties": {
              "oneOf": [
                { "type": "boolean" },
                { "type": "string", "enum": ["true", "false", "n/a"] }
              ]
            }
          },
          "expected_resolver": { "type": "string", "minLength": 1 },
          "allowed_resolvers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_confidence_range": {
            "type": "object",
            "required": ["min", "max"],
            "additionalProperties": false,
            "properties": {
              "min": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "max": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          },
          "expected_failure_mode": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "string",
                "enum": [
                  "no_candidate",
                  "wrong_candidate",
                  "ambiguous_candidate",
                  "low_confidence",
                  "validation_mismatch",
                  "stale_after_resolution",
                  "action_intercepted",
                  "unsupported_surface",
                  "provider_or_vision_unavailable",
                  "hydration_failed"
                ]
              }
            ]
          },
          "baseline_expectations": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "bubblegum_current",
              "playwright_raw_role_text",
              "llm_vision_raw",
              "manual_expected"
            ],
            "properties": {
              "bubblegum_current": { "type": "object", "additionalProperties": true },
              "playwright_raw_role_text": { "type": "object", "additionalProperties": true },
              "llm_vision_raw": { "type": "object", "additionalProperties": true },
              "manual_expected": { "type": "object", "additionalProperties": true }
            }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "anyOf": [
          { "required": ["expected_resolver"] },
          { "required": ["allowed_resolvers"] }
        ]
      }
    }
  }
}
