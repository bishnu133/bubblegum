    {
      "case_id": "oi_web_duplicate_label_disambiguated",
      "category": "duplicate_button_labels",
      "channel": "web",
      "platform_framework": "playwright",
      "fixture_path": "tests/fixtures/web/duplicate_labels_cart_checkout.html",
      "instruction": "Click the Checkout button in the cart summary.",
      "action_type": "click",
      "target_text": "Checkout",
      "expected_target": { "ref": "btn.checkout.cart_summary" },
      "acceptable_refs": ["btn.checkout.cart_summary"],
      "expected_relation": { "type": "within_region", "anchor_ref": "region.cart_summary" },
      "expected_graph_signals": { "has_role_match": true, "has_region_anchor": true, "has_label_match": true },
      "allowed_resolvers": ["accessibility_tree", "exact_text", "fuzzy_text"],
      "expected_confidence_range": { "min": 0.6, "max": 1.0 },
      "expected_failure_mode": null,
      "baseline_expectations": {
        "bubblegum_current": { "expected": "pass" },
        "playwright_raw_role_text": { "expected": "ambiguous_or_fail" },
        "llm_vision_raw": { "expected": "placeholder", "status": "not_automated_yet" },
        "manual_expected": { "expected": "btn.checkout.cart_summary" }
      },
      "tags": ["web", "duplicate-label", "positive", "seed"]
    },
