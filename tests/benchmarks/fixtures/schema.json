{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bubblegum benchmark fixture",
  "type": "object",
  "required": [
    "id",
    "category",
    "platform",
    "instruction",
    "action_type",
    "snapshot_path",
    "expected_resolver_winner",
    "confidence_min",
    "confidence_max"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string",
      "enum": [
        "web",
        "android"
      ]
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_path": {
      "type": "string",
      "minLength": 1
    },
    "expected_resolver_winner": {
      "type": "string",
      "minLength": 1
    },
    "confidence_min": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence_max": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "notes": {
      "type": "string"
    },
    "executable": {
      "type": "boolean"
    },
    "execute_expected_resolver_winner": {
      "type": "string",
      "minLength": 1
    },
    "execute_confidence_min": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "execute_confidence_max": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "execute_skip_reason": {
      "type": "string",
      "minLength": 1
    },
    "execute_allow_review": {
      "type": "boolean"
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "memory_seed": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ref",
            "confidence",
            "resolver_name"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "resolver_name": {
              "type": "string",
              "minLength": 1
            },
            "metadata": {
              "type": "object"
            },
            "force_memory_only": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
