{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bubblegum benchmark fixture",
  "type": "object",
  "required": [
    "id",
    "category",
    "platform",
    "instruction",
    "action_type",
    "snapshot_path",
    "expected_resolver_winner",
    "confidence_min",
    "confidence_max"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "category": {"type": "string", "minLength": 1},
    "platform": {"type": "string", "enum": ["web", "android"]},
    "instruction": {"type": "string", "minLength": 1},
    "action_type": {"type": "string", "minLength": 1},
    "snapshot_path": {"type": "string", "minLength": 1},
    "expected_resolver_winner": {"type": "string", "minLength": 1},
    "confidence_min": {"type": "number", "minimum": 0, "maximum": 1},
    "confidence_max": {"type": "number", "minimum": 0, "maximum": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
